{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/properties/(.*)", "dest": "/api/properties.js?id=$1" },
    { "src": "/api/properties", "dest": "/api/properties.js" },
    { "src": "/api/bookings/(.*)", "dest": "/api/bookings.js?id=$1" },
    { "src": "/api/bookings", "dest": "/api/bookings.js" },
    { "src": "/api/chefs/(.*)", "dest": "/api/chefs.js?id=$1" },
    { "src": "/api/chefs", "dest": "/api/chefs.js" },
    { "src": "/api/drivers/(.*)", "dest": "/api/drivers.js?id=$1" },
    { "src": "/api/drivers", "dest": "/api/drivers.js" },
    { "src": "/api/attractions/(.*)", "dest": "/api/attractions.js?id=$1" },
    { "src": "/api/attractions", "dest": "/api/attractions.js" },
    { "src": "/api/payments/mpesa/callback", "dest": "/api/payments.js?type=mpesa-callback" },
    { "src": "/api/payments/mpesa", "dest": "/api/payments.js?type=mpesa" },
    { "src": "/api/payments/card", "dest": "/api/payments.js?type=card" },
    { "src": "/api/reviews", "dest": "/api/reviews.js" },
    { "src": "/api/messages/(.*)", "dest": "/api/messages.js?id=$1" },
    { "src": "/api/messages", "dest": "/api/messages.js" },
    { "src": "/api/booking-notifications/(.*)", "dest": "/api/booking-notifications.js?id=$1" },
    { "src": "/api/booking-notifications", "dest": "/api/booking-notifications.js" },
    { "src": "/api/auth/(.*)", "dest": "/api/auth.js?action=$1" },
    { "src": "/api/upload", "dest": "/api/upload.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
